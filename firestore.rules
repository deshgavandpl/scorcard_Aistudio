rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all read/write for now to fix the database access error
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Explicitly handle subcollections if needed
    match /matches/{matchId}/chat/{messageId} {
      allow read, write: if true;
    }
    
    match /tournaments/{tournamentId} {
      allow read, write: if true;
    }
    
    match /teams/{teamId} {
      allow read, write: if true;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
