rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /matches/{matchId}/chat/{messageId} {
      allow read, write: if true;
    }

    // OPEN FOR ALL READ/WRITE AS REQUESTED
    // WARNING: This allows anyone to read or modify your data.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
