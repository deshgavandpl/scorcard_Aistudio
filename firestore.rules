rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: matches
    // Fields: id, teamAName, teamBName, status, createdAt, innings1, innings2, etc.
    //
    // Collection: tournaments
    // Fields: id, name, teams, matches, status
    //
    // Collection: teams
    // Fields: id, name, players
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "huseamol123@gmail.com" && request.auth.token.email_verified == true));
    }

    // Matches
    match /matches/{matchId} {
      allow read: if true; // Publicly readable for live scores
      allow write: if isAuthenticated(); // Only authenticated users can score
    }

    // Tournaments
    match /tournaments/{tournamentId} {
      allow read: if true; // Publicly readable
      allow write: if isAuthenticated();
    }

    // Teams
    match /teams/{teamId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
