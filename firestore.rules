rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read access for scores and standings
    match /matches/{matchId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if true;
    }
    
    match /teams/{teamId} {
      allow read: if true;
      allow write: if true;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default rule for any other collection
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
